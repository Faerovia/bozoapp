# ── Database ─────────────────────────────────────────────────────────────────
# Runtime: aplikace se připojuje jako bozoapp_app (least-privilege role
# vytvořená migrací 015). Pro dev/CI je hardcoded heslo "bozoapp_app_dev_secret".
# V produkci DBA vytvoří role s vlastním secure passwordem a natáhne ho sem.
DATABASE_URL=postgresql+asyncpg://bozoapp_app:bozoapp_app_dev_secret@localhost:5432/bozoapp_dev

# Migrace (alembic): jako owner `bozoapp` aby šly DDL příkazy.
# Fallback je DATABASE_URL pokud není nastaveno (pre-migration-015 chování).
MIGRATION_DATABASE_URL=postgresql+asyncpg://bozoapp:bozoapp_secret@localhost:5432/bozoapp_dev

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Min. 32 znaků; defaultní hodnota "change-me-generate-a-real-secret" je zablokována
SECRET_KEY=change-me-generate-a-real-secret

# ── CORS (produkce) ──────────────────────────────────────────────────────────
# Čárkami oddělený seznam povolených frontend origins. Required v produkci,
# jinak frontend selže na preflight requestu. Příklad:
# CORS_ORIGINS=https://app.bozoapp.cz,https://admin.bozoapp.cz
CORS_ORIGINS=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# Self-signup: anonymní POST /auth/register. V produkci DigitalOZO tenanty
# vytváří platform admin přes /admin/tenants → tady false.
ALLOW_SELF_SIGNUP=true

# ── Observability ─────────────────────────────────────────────────────────────
# Leave empty to disable Sentry locally
SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
