FROM python:3.12-slim

WORKDIR /app

# Systémové závislosti: fonty pro PDF generování (fpdf2 + DejaVu pro češtinu)
RUN apt-get update && apt-get install -y --no-install-recommends \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency installation
RUN pip install --no-cache-dir uv

# Install dependencies first (layer cache).
# Hatchling potřebuje app/__init__.py pro editable install,
# proto vytvoříme stub před instalací. Skutečný kód se překryje přes COPY níže.
COPY pyproject.toml .
RUN mkdir -p app && touch app/__init__.py
RUN uv pip install --system -e ".[dev]"

COPY . .

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
